generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                          String  @id
  name                        String
  description                 String  @default("")
  generally_available         String  @default("")
  gross_annual_price          Float   @default(0)
  platform_support_services_pct Float @default(0)
  professional_services_pct   Float   @default(0)
  software_resale_pct         Float   @default(0)
  cloud_consumption_pct       Float   @default(0)
  pss_pct                     Float   @default(0)
  user_count                  String  @default("")
  has_variants                Boolean @default(false)
  selected_variant            String?
  variants                    Json?
  status                      String  @default("live")
  readiness                   Json?
  sort_order                  Int     @default(0)

  salesMotion        SalesMotion?
  forecastEntries    ForecastEntry[]
  launchRequirements LaunchRequirement[]
}

model SalesMotion {
  id                           String @id @default(cuid())
  product_id                   String @unique
  sales_cycle_months           Int
  opp_to_close_win_rate_pct    Float
  prospect_to_opp_rate_pct     Float
  prospecting_lead_time_months Int

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model AppSettings {
  key   String @id
  value Json
}

model ForecastEntry {
  id         String @id @default(cuid())
  product_id String
  month      String
  quantity   Int

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, month])
}

model SavedForecast {
  id        String   @id
  name      String
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries SavedForecastEntry[]
}

model SavedForecastEntry {
  id          String @id @default(cuid())
  forecast_id String
  key         String
  quantity    Int

  forecast SavedForecast @relation(fields: [forecast_id], references: [id], onDelete: Cascade)

  @@unique([forecast_id, key])
}

model ContributorLock {
  contributor_id String  @id
  password       String  @default("")
  is_locked      Boolean @default(false)
}

model ContributorActual {
  id             String @id @default(cuid())
  contributor_id String
  metric_id      String
  month          String
  value          Float  @default(0)
  notes          String @default("")
  sources        String @default("")

  @@unique([contributor_id, metric_id, month])
}

model ContributorGoal {
  id             String @id @default(cuid())
  contributor_id String
  metric_id      String
  month          String
  value          Float  @default(0)

  @@unique([contributor_id, metric_id, month])
}

model SalesMotionTrackerState {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt
}

model LaunchRequirement {
  id           String @id @default(cuid())
  product_id   String
  deliverable  String
  owner        String @default("")
  criticalPath String @default("")
  timeline     String @default("")
  content      String @default("")
  dependency   String  @default("")
  complete     Boolean @default(false)
  sort_order   Int     @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, deliverable])
}

model AopMonthlyMetric {
  id        String   @id @default(cuid())
  dept      String   // department slug: cs | sales | partner | support
  kind      String   // metric kind: leading | lagging
  metric    String   // metric name from lib/aop/configs.ts
  month     String   // "YYYY-MM"
  value     Float    @default(0)
  notes     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([dept, kind, metric, month])
  @@index([dept])
}

model AopGoal {
  id          String @id @default(cuid())
  dept        String
  order       Int    @default(0)
  number      String @default("")
  title       String @default("")
  description String @default("")
  updatedAt   DateTime @updatedAt

  progress AopGoalProgress[]

  @@index([dept])
}

model AopGoalProgress {
  id        String   @id @default(cuid())
  goalId    String
  month     String   // "YYYY-MM"
  rag       String   @default("")  // red | amber | green | ""
  note      String   @default("")
  updatedAt DateTime @updatedAt

  goal AopGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, month])
}

model AopInitiative {
  id          String @id @default(cuid())
  dept        String
  order       Int    @default(0)
  area        String @default("")
  number      String @default("")
  description String @default("")
  owner       String @default("")
  q1Rag       String @default("")  // red | amber | green | ""
  q2Rag       String @default("")
  q3Rag       String @default("")
  q4Rag       String @default("")
  q1Note      String @default("")
  q2Note      String @default("")
  q3Note      String @default("")
  q4Note      String @default("")
  updatedAt   DateTime @updatedAt

  @@index([dept])
}

model AopInsight {
  id        String   @id @default(cuid())
  dept      String
  order     Int      @default(0)
  body      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dept])
}

model AopRetrospect {
  id        String   @id @default(cuid())
  dept      String
  kind      String   // "onTarget" | "offTarget" | "needChange" | "lessons"
  order     Int      @default(0)
  body      String   @default("")
  updatedAt DateTime @updatedAt

  @@index([dept, kind])
}
