# Supabase PostgreSQL connection
# Get these from: Supabase Dashboard > Project Settings > Database
# Use the "Connection string" (Transaction mode / port 6543) for DATABASE_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the "Direct connection" (Session mode / port 5432) for DIRECT_URL
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Admin passwords (change these!)
ADMIN_PASSWORD="changeme"
FORECAST_LOCK_PASSWORD="changeme"

# Salesforce JWT Bearer Flow (server-side only, read-only integration)
# All SFDC_* values come from the Connected App setup; private key stays on server.
SFDC_INSTANCE_URL="https://itmethods.my.salesforce.com"
SFDC_LOGIN_URL="https://login.salesforce.com"
SFDC_CLIENT_ID="<Consumer Key from Connected App>"
SFDC_USERNAME="gtm_tracker_sfdc@itmethods.com"
# Paste the full PEM including BEGIN/END lines. Use real newlines in .env,
# or escape with \n if your env manager requires a single line.
SFDC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
SFDC_API_VERSION="62.0"
